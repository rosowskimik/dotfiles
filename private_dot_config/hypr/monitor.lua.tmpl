------------------
---- MONITORS ----
------------------
{{ if eq .chezmoi.hostname "ThinkBookArch" -}}
hl.monitor({
	output = "eDP-1",
	mode = "1920x1200@60",
	position = "0x0",
	scale = 1,
	vrr = 2,
	cm = "auto",
})
{{- else if eq .chezmoi.hostname "B650Arch" }}
hl.monitor({
	output = "DP-1",
	mode = "2560x1440@144",
	position = "0x0",
	scale = 1,
	vrr = 2,
	cm = "auto",
})

hl.monitor({
	output = "DP-2",
	mode = "2560x1440@75",
	position = "auto-right",
	scale = 1,
})
{{- else if eq .chezmoi.hostname "ant"}}
hl.monitor({
	output = "DP-2",
	mode = "2560x1440@60",
	position = "0x0",
	scale = 1,
	vrr = 2,
	cm = "auto",
})

hl.monitor({
	output = "HDMI-A-1",
	mode = "2560x1440@60",
	position = "auto-right",
	scale = 1,
	vrr = 2,
	cm = "auto",
})
{{- end }}

hl.monitor({
	output = "",
	mode = "preferred",
	position = "auto",
	scale = 1,
})

